meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "runner@example.com",
    "password": "password123",
    "displayName": "Runner One"
  }
}

vars:pre-request {
  baseUrl: http://127.0.0.1:3000
}
